<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:MyAvaloniaApp.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MyAvaloniaApp.Views.Example">
    <!-- SizeToContent="WidthAndHeight" -->
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..."/>
                <Separator/>
                <MenuItem Header="_Exit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Copy"/>
                <MenuItem Header="Paste"/>
            </MenuItem>
        </Menu>
        <StackPanel Background="#aaaaaa">
            <TextBlock Margin="12" Text="Navigation"/>
            <TextBlock Margin="12" Text="Home"/>
            <TextBlock Margin="12" Text="Settings"/>
            <TextBlock Margin="12" Text="Profile"/>
        </StackPanel>
        <Canvas>
            <Rectangle Canvas.Left="100" Canvas.Top="50"  Width="100" Height="50" Fill="#ff0000" />
        </Canvas>
    </DockPanel>
</UserControl>
